// Provider is swapped at build-time by scripts/prisma-provider.mjs based on
// the PRISMA_PROVIDER env var (default: keep sqlite for local dev; set to
// "postgresql" in CI/Vercel prod). Do NOT edit the provider line by hand for prod.
//
// Hearst Connect — Prisma schema
// MVP tables. Postgres in production, SQLite for local dev.
// Source of truth for data model: /docs/spec/* + plan section 15.
//
// RLS / multi-tenant isolation (P0):
//   userId columns added to Feedback, ReportExport, LlmRun (+ ScenarioRun).
//   No formal SQL migration here (sqlite local, db push workflow).
//   Apply with: `pnpm db:push` then `pnpm db:generate`.
//
// PRISMA 7 UPGRADE NOTE
//   `url = env("DATABASE_URL")` is no longer allowed in the schema.
//   The runtime PrismaClient is now constructed with a driver adapter
//   (`@prisma/adapter-better-sqlite3` for dev / `@prisma/adapter-pg` for prod);
//   see `src/lib/db.ts`. The CLI (`prisma generate / db push / migrate / studio`)
//   reads its connection through `prisma.config.ts` (also env-driven).

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider = "sqlite"
}

// =============================================================================
// VAULT STATE — time-series snapshots
// =============================================================================

model VaultSnapshot {
  id                String   @id @default(cuid())
  takenAt           DateTime @default(now())
  aumUsdc           Decimal
  currentApyLow     Decimal
  currentApyHigh    Decimal
  stressedApy       Decimal
  riskScore         Int
  miningMarginScore Int
  mode              String // defensive | balanced | opportunistic
  source            String   @default("computed")

  allocations Allocation[]

  @@index([takenAt])
}

model Allocation {
  id                   String        @id @default(cuid())
  snapshotId           String
  snapshot             VaultSnapshot @relation(fields: [snapshotId], references: [id], onDelete: Cascade)
  bucket               String // mining | btc_tactical | usdc_base | stable_reserve
  pct                  Decimal
  valueUsdc            Decimal
  yieldContributionBps Decimal

  @@index([snapshotId])
}

// =============================================================================
// MINING — daily metrics
// =============================================================================

model MiningMetric {
  id                    String   @id @default(cuid())
  takenAt               DateTime @default(now())
  hashprice             Decimal // $/TH/day
  difficulty            Decimal
  btcPrice              Decimal
  energyCost            Decimal // $/kWh
  uptimePct             Decimal
  deployedHashrate      Decimal // TH/s
  miningMarginScore     Int
  hashpriceTrendPct     Decimal
  operationalConfidence Int
  alertLevel            String? // green | amber | red
  summary               String?
  recommendation        String?

  @@index([takenAt])
}

// =============================================================================
// SCENARIOS & BACKTESTS
// =============================================================================

model ScenarioRun {
  id                 String   @id @default(cuid())
  ranAt              DateTime @default(now())
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
  userId             String
  preset             String? // base | btc_bear | btc_bull | mining_compression | extreme_stress
  inputs             String // JSON: { btc_price_change, hashprice, energy, stable_apy, vol }
  outputs            String // JSON: ScenarioOutput
  status             String   @default("completed") // completed | failed
  narrative          String?
  riskWarning        String?
  confidence         String   @default("medium") // low | medium | high
  methodologyVersion String   @default("v1.0")

  @@index([ranAt])
  @@index([userId, ranAt])
  @@index([userId, createdAt])
}

model BacktestRun {
  id             String   @id @default(cuid())
  backtestKey    String // bear_2022 | etf_halving_2024 | mining_crunch_2024
  ranAt          DateTime @default(now())
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  userId         String
  initialCapital Decimal
  rulesMode      String // hearst_rules | without_rules
  endingValue    Decimal
  totalReturnPct Decimal
  maxDrawdownPct Decimal
  worstMonthPct  Decimal
  numRebalances  Int
  monthlySeries  String // JSON: [{ month, value, distribution }]
  narrative      String?

  @@index([backtestKey])
  @@index([userId, createdAt])
}

// =============================================================================
// EVENTS — rebalancing, distributions, proofs
// =============================================================================

model RebalanceEvent {
  id              String   @id @default(cuid())
  executedAt      DateTime @default(now())
  ruleId          String // e.g. "R2", "R-BTC-3"
  triggerText     String // plain English — PTAI Trigger
  actionText      String // PTAI Action
  impactText      String // PTAI Impact
  projection      String   @default("") // PTAI Projection (was previously embedded into triggerText)
  status          String   @default("pending") // pending | approved | executed | cancelled
  triggeredAt     DateTime @default(now()) // when the signal fired (distinct from executedAt)
  sourceEventName String? // Inngest source event name (e.g. "risk.daily.completed")
  sourceEventId   String? // Inngest event id for traceability
  fromAllocation  String // JSON
  toAllocation    String // JSON
  txHash          String? // Phase 2+
  approvedBy      String // JSON array of multisig signers

  @@index([executedAt])
  @@index([status, triggeredAt])
}

model Distribution {
  id              String                    @id @default(cuid())
  distributedAt   DateTime
  amountUsdc      Decimal
  txHash          String?
  recipientsCount Int
  period          String // "2026-04"
  // Vault reference — slug or ticker (vaultSlug(ref)) identifying which vault
  // this distribution belongs to. Optional for backward compatibility with
  // historical rows created before multi-vault support (mvp-plus, 2026-05-26).
  vaultRef        String?
  // Atomic exec status + back-relations (Carta pattern, EE).
  status          String                    @default("pending")
  executedAt      DateTime?
  ledgerEntries   DistributionLedgerEntry[]

  @@index([distributedAt])
  @@index([vaultRef])
}

/**
 * Pending multisig approvals for a distribution.
 * Each row represents one signer's confirmation for a given period.
 * The first signer locks in the reference `totalUsdc` amount;
 * subsequent signers must match the same amount.
 * @@unique([period, signerWallet]) enforces idempotence:
 * a signer can only approve once per period.
 */
model DistributionApproval {
  id           String   @id @default(cuid())
  period       String
  signerWallet String
  totalUsdc    Decimal
  createdAt    DateTime @default(now())

  @@unique([period, signerWallet])
  @@index([period])
}

model Proof {
  id        String   @id @default(cuid())
  proofType String // mining_attestation | custody | audit | methodology
  period    String?
  hash      String // bytes32 hex
  uri       String // IPFS or HTTPS
  postedAt  DateTime @default(now())
  postedBy  String
  txHash    String?
  notes     String? // free-form admin annotation (Zod-validated ≤ 500 chars at ingest)

  // Off-chain attestation signature (mining_attestation only; null otherwise).
  // `hash` doubles as the keccak256 digest; `signer` must recover from `signature`
  // over that digest. `payloadJson` is the canonical payload, enabling end-to-end
  // re-verification at read time. See src/lib/attestation.
  signer      String? // attestor address (0x…)
  signature   String? // EIP-191 signature over `hash`
  payloadJson String? // canonical MiningAttestationPayload as JSON

  @@index([proofType, period])
}

// =============================================================================
// REPORTS — investor memo exports
// =============================================================================

model ReportExport {
  id                 String   @id @default(cuid())
  generatedAt        DateTime @default(now())
  generatedBy        String
  clientName         String
  scenariosIncluded  String // JSON array
  backtestsIncluded  String // JSON array
  methodologyVersion String
  pdfUrl             String?
  content            String? // JSON: full InvestorMemoOutput
  userId             String? // RLS owner — nullable for legacy rows / background jobs
  updatedAt          DateTime @updatedAt

  @@index([generatedAt])
  @@index([userId, generatedAt])
}

// =============================================================================
// ADMIN — roadmap validation + feedback
// =============================================================================

model RoadmapValidation {
  id          String    @id @default(cuid())
  itemId      String    @unique // FK virtual to docs/roadmap.json items
  status      String    @default("todo") // todo | in_progress | done | blocked | validated
  validatedBy String?
  validatedAt DateTime?
  notes       String?
  blockers    String?
  evidenceUrl String?
  updatedAt   DateTime  @updatedAt

  @@index([status])
}

model Feedback {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  itemId    String? // optional link to a roadmap item
  pathname  String? // page where feedback was submitted
  message   String
  author    String? // optional name
  resolved  Boolean  @default(false)
  userId    String? // RLS owner — nullable for legacy rows / anon feedback
  updatedAt DateTime @updatedAt

  @@index([createdAt])
  @@index([itemId])
  @@index([userId, createdAt])
}

// =============================================================================
// COCKPIT CHAT — persistent chat threads (isolation by Privy userId at app layer)
// =============================================================================

model CockpitChat {
  id        String           @id @default(cuid())
  userId    String // Privy DID
  title     String?
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt
  messages  CockpitMessage[]

  @@index([userId, updatedAt])
}

model CockpitMessage {
  id        String      @id @default(cuid())
  chatId    String
  chat      CockpitChat @relation(fields: [chatId], references: [id], onDelete: Cascade)
  role      String // 'user' | 'assistant' | 'system'
  content   String
  // Persona under which this message was exchanged: "normal" (default
  // assistant) or "review" (admin product-review facilitator). Stamped at
  // write time from AdminChatMode so the review-document generator can
  // filter on exactly the messages produced in review sessions, avoiding
  // contamination by normal-mode chatter that happened in the same chat row.
  mode      String      @default("normal")
  createdAt DateTime    @default(now())

  @@index([chatId, createdAt])
  @@index([chatId, mode])
}

// =============================================================================
// AUTH — database email/password identity + opaque server sessions
// =============================================================================
//
// Authentication (dashboard access) is email + password, backed by these
// tables. Privy is NOT part of auth — it is reserved for the USDC subscription
// /payment flow only (wallet connect at deposit time). The session token is the
// opaque `Session.id` (a cuid), stored in the httpOnly `hc_session` cookie.

model User {
  id           String    @id @default(cuid())
  email        String    @unique
  passwordHash String
  role         String    @default("investor") // investor | admin
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  sessions     Session[]
  investor     Investor?
}

model Session {
  id        String   @id @default(cuid()) // opaque session token (cuid)
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([userId])
}

// =============================================================================
// CUSTOMER — investors, positions, transactions
// =============================================================================

model Investor {
  id            String   @id @default(cuid())
  userId        String   @unique // FK → User.id (auth identity)
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  walletAddress String?  @unique // nullable — set when the investor connects a wallet for payment
  email         String?
  kycStatus     String   @default("pending") // pending|approved|rejected
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  positions    Position[]
  transactions InvestorTransaction[]

  @@index([walletAddress])
}

model Position {
  id                String           @id @default(cuid())
  investorId        String
  investor          Investor         @relation(fields: [investorId], references: [id])
  vaultDeploymentId String?
  vaultDeployment   VaultDeployment? @relation(fields: [vaultDeploymentId], references: [id])
  vaultKey          String           @default("hearst_yield_vault") // single vault MVP fallback
  principalUsdc     Decimal
  accruedYieldUsdc  Decimal          @default(0)
  distributedUsdc   Decimal          @default(0)
  status            String           @default("active") // active|matured|exited
  subscribedAt      DateTime         @default(now())
  maturedAt         DateTime?
  exitedAt          DateTime?
  txHashOpen        String?

  transactions InvestorTransaction[]

  @@index([investorId, status])
  @@index([vaultDeploymentId])
}

model InvestorTransaction {
  id         String    @id @default(cuid())
  investorId String
  investor   Investor  @relation(fields: [investorId], references: [id])
  positionId String?
  position   Position? @relation(fields: [positionId], references: [id])
  type       String // deposit|claim|withdraw|distribution
  amountUsdc Decimal
  txHash     String?
  occurredAt DateTime  @default(now())

  @@index([investorId, occurredAt])
}

// =============================================================================
// ADMIN — vault deployments, approvals, projection studies, audit trail
// =============================================================================

model VaultDeployment {
  id                     String    @id @default(cuid())
  ticker                 String    @unique // e.g. "HYV-A"
  name                   String
  description            String?
  strategy               String // mining_yield | btc_tactical | stable_reserve
  colorTag               String    @default("accent")
  status                 String    @default("draft") // draft|review|deployed|live|paused|closed
  minTicketUsdc          Decimal
  capacityUsdc           Decimal
  mgmtFeeBps             Int       @default(200)
  perfFeeBps             Int       @default(1000)
  hurdleBps              Int       @default(0)
  softLockupDays         Int       @default(60)
  targetApyLowBps        Int
  targetApyHighBps       Int
  spvJurisdiction        String // cayman|bvi|delaware|lux
  shareClass             String    @default("A")
  regExemption           String // regD_506c|regS|art2_lux
  disclaimers            String
  targetMiningBps        Int
  targetBtcTacticalBps   Int
  targetUsdcBaseBps      Int
  targetStableReserveBps Int
  network                String?
  contractAddress        String?
  requiredSigners        Int       @default(2)
  signersWhitelist       String // JSON array
  createdAt              DateTime  @default(now())
  updatedAt              DateTime  @updatedAt
  submittedAt            DateTime?
  deployedAt             DateTime?
  pausedAt               DateTime?
  closedAt               DateTime?
  createdBy              String
  seededFromStudyId      String?

  approvals VaultDeploymentApproval[]
  positions Position[]
  proposals GovernanceProposal[]

  @@index([status])
  @@index([strategy, status])
}

model VaultDeploymentApproval {
  id           String          @id @default(cuid())
  deploymentId String
  deployment   VaultDeployment @relation(fields: [deploymentId], references: [id], onDelete: Cascade)
  signerWallet String
  signedAt     DateTime        @default(now())
  decision     String // approve|reject
  reason       String?

  @@unique([deploymentId, signerWallet])
  @@index([deploymentId])
}

model ProjectionStudyRun {
  id                 String   @id @default(cuid())
  ranAt              DateTime @default(now())
  createdBy          String
  label              String?
  presetIds          String // JSON array
  matrixSize         Int      @default(1)
  scenarioRunIds     String // JSON array
  methodologyVersion String   @default("v1.0")
  summary            String?
  notes              String?

  @@index([ranAt])
  @@index([createdBy, ranAt])
}

model AdminAudit {
  id          String   @id @default(cuid())
  occurredAt  DateTime @default(now())
  actorWallet String
  action      String
  entityType  String
  entityId    String
  diff        String // JSON { before, after }
  ip          String?
  userAgent   String?

  @@index([occurredAt])
  @@index([actorWallet, occurredAt])
  @@index([entityType, entityId])
}

// =============================================================================
// CUSTOMER — per-user agent persona + memory preferences
// =============================================================================

model UserAgentProfile {
  id                 String   @id @default(cuid())
  userId             String
  agentName          String // "scenario-narrative" | "investor-memo" | "mining-health" | "risk-explanation" | "cockpit-chat"
  tone               String? // ex: "concise" | "detailed" | "technical"
  language           String? // ex: "fr" | "en"
  verbosity          String? // ex: "low" | "medium" | "high"
  customInstructions String? // texte libre, validé forbidden-words avant injection
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  @@unique([userId, agentName])
  @@index([userId])
}

// =============================================================================
// ADMIN REVIEW — head-of-product walkthrough copilot
// =============================================================================
//
// The admin cockpit chat can run in two modes: "normal" (assistant) or
// "review" (a facilitator persona that probes the platform A→Z and whose
// conversation can be distilled into a structured change document).
// Mode is per-user state (one row per admin), read by the cockpit-chat route
// to swap the system prompt — the package chat UI cannot carry the flag itself.

model AdminChatMode {
  userId    String   @id
  mode      String   @default("normal") // normal | review
  updatedAt DateTime @updatedAt
}

// A generated "suggested modifications" document, distilled from a review-mode
// conversation. Kept append-only (history of generations) and scoped per user.
model ReviewDocument {
  id          String   @id @default(cuid())
  userId      String
  chatId      String?
  contentMd   String
  contentJson String? // JSON sérialisé (cf. ReviewDocumentJsonSchema), null si parsing failed
  createdAt   DateTime @default(now())

  @@index([userId, createdAt])
}

// =============================================================================
// VAULT WIZARD — per-admin WIP draft autosave
// =============================================================================

model VaultDraft {
  id        String   @id @default(cuid())
  userId    String
  formState String // JSON serialized FormState
  step      String // current step key
  updatedAt DateTime @updatedAt
  createdAt DateTime @default(now())

  @@unique([userId])
  @@index([userId])
}

// =============================================================================
// GOVERNANCE — multisig proposal + timelock state machine (UI+DB; no Solidity)
// =============================================================================

model GovernanceProposal {
  id                String              @id @default(cuid())
  vaultDeploymentId String
  vault             VaultDeployment     @relation(fields: [vaultDeploymentId], references: [id], onDelete: Cascade)
  actionType        String // "deploy" | "pause" | "unpause" | "updateFees" | "updateCaps" | "rotateSigners" | "sweepFees" | "emergencyShutdown"
  calldata          String? // JSON or hex stub
  justification     String // min 80 chars
  state             String              @default("DRAFT")
  proposedBy        String // wallet address
  requiredSigners   Int // copied from vault at proposal time
  cancelQuorum      Int                 @default(2)
  timelockHours     Int                 @default(48)
  graceWindowDays   Int                 @default(7)
  createdAt         DateTime            @default(now())
  submittedAt       DateTime?
  queuedAt          DateTime?
  etaAt             DateTime?
  executedAt        DateTime?
  cancelledAt       DateTime?
  signatures        ProposalSignature[]

  @@index([vaultDeploymentId, state])
  @@index([state])
}

model ProposalSignature {
  id            String             @id @default(cuid())
  proposalId    String
  proposal      GovernanceProposal @relation(fields: [proposalId], references: [id], onDelete: Cascade)
  signerAddress String
  decision      String // "approve" | "reject" | "cancel"
  reason        String?
  signedAt      DateTime           @default(now())

  @@unique([proposalId, signerAddress, decision])
  @@index([proposalId])
}

// =============================================================================
// NOTIFICATIONS — per-user notification feed (action / fyi / system)
// =============================================================================

model Notification {
  id           String    @id @default(cuid())
  userId       String // recipient admin
  category     String // "action" | "fyi" | "system"
  severity     String    @default("info") // "urgent" | "info" | "low"
  title        String
  body         String
  actionHref   String?
  actionLabel  String?
  entityType   String?
  entityId     String?
  readAt       DateTime?
  archivedAt   DateTime?
  snoozedUntil DateTime?
  createdAt    DateTime  @default(now())

  @@index([userId, readAt])
  @@index([userId, category])
}

// =============================================================================
// LLM OBSERVABILITY — every agent call is traced here
// =============================================================================

model LlmRun {
  id                       String   @id @default(cuid())
  createdAt                DateTime @default(now())
  agentName                String
  model                    String
  promptHash               String?
  inputTokens              Int?
  outputTokens             Int?
  // Prompt caching observability (Anthropic ephemeral cache).
  // Both nullable — legacy rows stay NULL, and providers without caching
  // (e.g. Kimi fallback) also persist NULL here.
  cacheCreationInputTokens Int? // tokens written to cache (first occurrence)
  cacheReadInputTokens     Int? // tokens read from cache on subsequent hits
  systemPromptHash         String? // sha256(system blocks) — groups runs by prompt version
  latencyMs                Int?
  status                   String // queued | success | failed | timeout | fallback
  errorType                String?
  errorMessage             String?
  costUsd                  Float?
  userId                   String? // RLS owner — nullable for system / background agent runs

  @@index([createdAt])
  @@index([agentName])
  @@index([status])
  @@index([userId, createdAt])
  @@index([systemPromptHash])
}

// =============================================================================
// SAVED VIEWS — Linear-style per-user filter/sort/column presets per table
// =============================================================================

model SavedView {
  id         String   @id @default(cuid())
  userId     String
  name       String
  scope      String
  filters    String
  sort       String?
  columns    String?
  visibility String   @default("private")
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([userId, scope])
}

// =============================================================================
// ADDRESS ALLOWLIST — governance routing decision input (Anchorage pattern)
// =============================================================================

model AddressAllowlist {
  id        String   @id @default(cuid())
  address   String   @unique
  label     String
  category  String
  addedBy   String
  addedAt   DateTime @default(now())
  notes     String?
  riskScore Int      @default(0)
  active    Boolean  @default(true)

  @@index([active, category])
}

// =============================================================================
// DISTRIBUTION LEDGER — per-LP entries from atomic distribution exec (Carta pattern)
// =============================================================================

model DistributionLedgerEntry {
  id             String       @id @default(cuid())
  distributionId String
  distribution   Distribution @relation(fields: [distributionId], references: [id], onDelete: Cascade)
  positionId     String
  amountUsdc     Decimal
  createdAt      DateTime     @default(now())

  @@index([distributionId])
  @@index([positionId])
}

model Pcap {
  id             String   @id @default(cuid())
  distributionId String?
  generatedAt    DateTime @default(now())
  pdfUrl         String?
  generatedFor   String
}
