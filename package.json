{
  "name": "hearst-connect",
  "version": "0.1.0",
  "engines": {
    "node": ">=22.0.0",
    "pnpm": ">=10.0.0"
  },
  "private": true,
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "next dev -p 4105",
    "build": "NODE_ENV=production next build",
    "start": "next start -p 4105",
    "lint": "eslint src",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:migrate": "prisma migrate dev",
    "db:studio": "prisma studio",
    "db:seed": "tsx prisma/seed.ts",
    "electron:compile": "tsc -p electron",
    "electron:dev": "concurrently -k -n next,electron -c blue,magenta \"pnpm dev\" \"wait-on http://localhost:4105 && pnpm electron:compile && cross-env ELECTRON_RUN_AS_NODE= electron .\"",
    "electron:start": "pnpm electron:compile && cross-env ELECTRON_RUN_AS_NODE= electron .",
    "electron:test": "pnpm electron:compile && cross-env ELECTRON_RUN_AS_NODE= playwright test electron/__tests__",
    "electron:build": "pnpm electron:compile && electron-builder --publish never",
    "electron:publish": "pnpm electron:compile && electron-builder --publish always"
  },
  "build": {
    "appId": "com.hearst.connect.desktop",
    "productName": "Hearst Connect",
    "files": [
      "dist-electron/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "electron/splash.html",
        "to": "splash.html"
      }
    ],
    "mac": {
      "category": "public.app-category.finance",
      "target": [
        "dmg",
        "zip"
      ],
      "hardenedRuntime": true,
      "gatekeeperAssess": false,
      "entitlements": "electron/entitlements.mac.plist",
      "entitlementsInherit": "electron/entitlements.mac.plist",
      "notarize": false
    },
    "win": {
      "target": [
        "nsis"
      ]
    },
    "linux": {
      "target": [
        "AppImage",
        "deb"
      ],
      "category": "Finance"
    },
    "publish": {
      "provider": "github",
      "owner": "Hearst-Corporation",
      "repo": "Hearst-Defi",
      "releaseType": "release"
    }
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.96.0",
    "@hearst/cockpit-shell": "file:./hearst-cockpit-shell-0.2.0.tgz",
    "@hearst/hub-sdk": "file:./hearst-hub-sdk-0.2.0.tgz",
    "@mdx-js/loader": "^3.1.1",
    "@mdx-js/react": "^3.1.1",
    "@next/mdx": "^16.2.6",
    "@prisma/client": "^6.19.3",
    "@privy-io/react-auth": "^3.25.0",
    "@privy-io/server-auth": "^1.32.5",
    "@radix-ui/react-slot": "^1.2.4",
    "@react-pdf/renderer": "^4.5.1",
    "@sentry/nextjs": "^10.53.1",
    "@upstash/redis": "^1.38.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "dompurify": "^3.2.0",
    "framer-motion": "^12.38.0",
    "gray-matter": "^4.0.3",
    "inngest": "^4.4.0",
    "jose": "^6.2.3",
    "lucide-react": "^1.14.0",
    "next": "^16.2.6",
    "openai": "^6.38.0",
    "posthog-js": "^1.373.5",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1",
    "server-only": "^0.0.1",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.6.0",
    "viem": "^2.48.11",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@tailwindcss/postcss": "^4.3.0",
    "@types/dompurify": "^3.2.0",
    "@types/electron": "^1.6.12",
    "@types/node": "^25.7.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "autoprefixer": "^10.5.0",
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "electron": "^42.2.0",
    "electron-builder": "^26.8.1",
    "electron-updater": "^6.8.3",
    "eslint": "^10.3.0",
    "eslint-config-next": "^16.2.6",
    "postcss": "^8.5.14",
    "prettier": "^3.8.3",
    "prettier-plugin-tailwindcss": "^0.8.0",
    "prisma": "^6.19.3",
    "tailwindcss": "^4.3.0",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.6",
    "wait-on": "^9.0.10"
  }
}
