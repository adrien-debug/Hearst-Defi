{
  "name": "hearst-connect",
  "version": "0.1.0",
  "engines": {
    "node": "22.x",
    "pnpm": ">=10.0.0"
  },
  "private": true,
  "main": "dist-electron/main.js",
  "scripts": {
    "predev": "node scripts/free-port.mjs",
    "dev": "NODE_OPTIONS=--max-http-header-size=65536 next dev -p 4105",
    "build": "node scripts/prisma-provider.mjs && prisma generate && NODE_ENV=production next build",
    "start": "next start -p 4105",
    "lint": "eslint src",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "db:generate": "node scripts/prisma-provider.mjs && prisma generate",
    "db:push": "prisma db push",
    "db:migrate": "prisma migrate dev",
    "db:studio": "prisma studio",
    "db:seed": "tsx prisma/seed.ts",
    "db:backfill": "tsx prisma/backfill.ts",
    "seed:test": "tsx scripts/seed-test-user.ts",
    "electron:compile": "tsc -p electron",
    "electron:dev": "concurrently --restart-tries 3 --restart-after 2000 -n next,electron -c blue,magenta \"pnpm dev\" \"wait-on http://localhost:4105 && pnpm electron:compile && cross-env ELECTRON_RUN_AS_NODE= electron .\"",
    "electron:start": "pnpm electron:compile && cross-env ELECTRON_RUN_AS_NODE= electron .",
    "electron:test": "pnpm electron:compile && cross-env ELECTRON_RUN_AS_NODE= playwright test electron/__tests__",
    "electron:build": "pnpm electron:compile && electron-builder --publish never",
    "electron:publish": "pnpm electron:compile && electron-builder --publish always"
  },
  "build": {
    "appId": "com.hearst.connect.desktop",
    "productName": "Hearst Connect",
    "directories": {
      "output": "release"
    },
    "npmRebuild": false,
    "files": [
      "dist-electron/**/*",
      "package.json",
      "!node_modules/**/*",
      "node_modules/electron-updater/**/*",
      "node_modules/builder-util-runtime/**/*",
      "node_modules/argparse/**/*",
      "node_modules/debug/**/*",
      "node_modules/ms/**/*",
      "node_modules/fs-extra/**/*",
      "node_modules/graceful-fs/**/*",
      "node_modules/js-yaml/**/*",
      "node_modules/jsonfile/**/*",
      "node_modules/lazy-val/**/*",
      "node_modules/lodash.escaperegexp/**/*",
      "node_modules/lodash.isequal/**/*",
      "node_modules/sax/**/*",
      "node_modules/semver/**/*",
      "node_modules/tiny-typed-emitter/**/*",
      "node_modules/universalify/**/*"
    ],
    "extraResources": [
      {
        "from": "electron/splash.html",
        "to": "splash.html"
      }
    ],
    "mac": {
      "category": "public.app-category.finance",
      "icon": "build/icon.icns",
      "target": [
        {
          "target": "dmg",
          "arch": [
            "arm64",
            "x64"
          ]
        },
        {
          "target": "zip",
          "arch": [
            "arm64",
            "x64"
          ]
        }
      ],
      "hardenedRuntime": true,
      "gatekeeperAssess": false,
      "entitlements": "electron/entitlements.mac.plist",
      "entitlementsInherit": "electron/entitlements.mac.plist",
      "notarize": true
    },
    "win": {
      "target": [
        "nsis"
      ]
    },
    "linux": {
      "target": [
        "AppImage",
        "deb"
      ],
      "category": "Finance"
    },
    "publish": {
      "provider": "github",
      "owner": "Hearst-Corporation",
      "repo": "Hearst-Defi",
      "releaseType": "release"
    }
  },
  "dependencies": {
    "@fireblocks/ts-sdk": "^19.0.0",
    "@hearst/cockpit-shell": "file:./hearst-cockpit-shell-0.2.0.tgz",
    "@hearst/hub-sdk": "file:./hearst-hub-sdk-0.2.0.tgz",
    "@hearst/review-mode": "file:./hearst-review-mode-0.1.0.tgz",
    "@mdx-js/loader": "^3.1.1",
    "@mdx-js/react": "^3.1.1",
    "@next/mdx": "^16.2.6",
    "@node-rs/argon2": "^2.0.2",
    "@prisma/adapter-better-sqlite3": "^7.8.0",
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "@privy-io/react-auth": "^3.25.0",
    "@privy-io/server-auth": "^1.32.5",
    "@radix-ui/react-slot": "^1.2.4",
    "@react-pdf/renderer": "^4.5.1",
    "@sentry/nextjs": "^10.53.1",
    "@upstash/redis": "^1.38.0",
    "better-sqlite3": "^12.10.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "dompurify": "^3.2.0",
    "electron-updater": "^6.8.3",
    "framer-motion": "^12.38.0",
    "gray-matter": "^4.0.3",
    "inngest": "^4.4.0",
    "jose": "^6.2.3",
    "lucide-react": "^1.14.0",
    "next": "^16.2.6",
    "openai": "^6.38.0",
    "otpauth": "^9.5.1",
    "pg": "^8.21.0",
    "posthog-js": "^1.373.5",
    "qrcode": "^1.5.4",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1",
    "server-only": "^0.0.1",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.6.0",
    "viem": "^2.48.11",
    "zod": "^4.4.3"
  },
  "pnpm": {
    "overrides": {
      "ws": ">=8.20.1",
      "js-cookie": ">=3.0.7",
      "postcss": ">=8.5.10",
      "uuid": ">=11.1.1",
      "@hono/node-server": ">=1.19.13"
    },
    "onlyBuiltDependencies": [
      "@prisma/client",
      "@prisma/engines",
      "prisma",
      "better-sqlite3"
    ]
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@tailwindcss/postcss": "^4.3.0",
    "@types/node": "^25.7.0",
    "@types/pg": "^8.20.0",
    "@types/qrcode": "^1.5.6",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "autoprefixer": "^10.5.0",
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "electron": "^42.2.0",
    "electron-builder": "^26.8.1",
    "eslint": "^10.3.0",
    "eslint-config-next": "^16.2.6",
    "knip": "^6.14.2",
    "postcss": "^8.5.14",
    "prettier": "^3.8.3",
    "prettier-plugin-tailwindcss": "^0.8.0",
    "prisma": "^7.8.0",
    "tailwindcss": "^4.3.0",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.6",
    "wait-on": "^9.0.10"
  }
}
