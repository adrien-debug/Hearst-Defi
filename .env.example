# Local dev: SQLite
DATABASE_URL="file:./prisma/dev.db"

# Production (Supabase): replace with Postgres connection string
# DATABASE_URL="postgresql://..."

# Anthropic API key (Phase 2+, for agents)
# ANTHROPIC_API_KEY=""

# Privy auth (https://dashboard.privy.io — create an app, copy the App ID and Secret).
# Public app id is read by the client SDK; the secret is server-only.
# Leave both blank in local dev to disable the gate (homepage + /admin remain open,
# /dashboard and the rest of the (product) group skip the middleware check).
NEXT_PUBLIC_PRIVY_APP_ID=
PRIVY_APP_SECRET=

# Future:
# UPSTASH_REDIS_REST_URL=""
# UPSTASH_REDIS_REST_TOKEN=""

# Phase 2 smart contracts (Base Sepolia) — fill in after `forge script` deploy.
NEXT_PUBLIC_EVENT_LOGGER_ADDRESS=
NEXT_PUBLIC_POR_REGISTRY_ADDRESS=
NEXT_PUBLIC_CHAIN_RPC_URL=https://sepolia.base.org
