# =============================================================================
# REQUIRED
# =============================================================================

# Local dev: SQLite. Production: Postgres connection string.
# Path is resolved relative to prisma/schema.prisma (Prisma 5+ behaviour), so
# the file actually lives at prisma/dev.db on disk.
DATABASE_URL="file:./prisma/dev.db"

# Prisma provider switch (sqlite local / postgresql prod)
# Read at build time by scripts/prisma-provider.mjs to rewrite datasource in schema.prisma.
# Values: sqlite (default local) | postgresql (Vercel/prod)
PRISMA_PROVIDER=sqlite

# =============================================================================
# LLM (Anthropic) — required for agents (Investor Memo, Scenario Narrative,
# Mining Health, Risk Explanation). Leave blank to disable LLM features.
# =============================================================================
ANTHROPIC_API_KEY=""

# =============================================================================
# AUTH (database email/password) — admin bootstrap
# Authentication is email + password, backed by the DB (hc_session cookie).
# ADMIN_EMAILS: comma-separated emails seeded as role=admin by `pnpm db:seed`.
# ADMIN_INITIAL_PASSWORD: initial password applied to those admin accounts.
# The seed is idempotent and a no-op when either is blank.
# =============================================================================
ADMIN_EMAILS=""
ADMIN_INITIAL_PASSWORD=""

# DEV ONLY — auth bypass. Set DEV_AUTH_BYPASS="1" in local dev to skip login
# and reach protected routes directly as a seeded dev investor. DOUBLE-GATED:
# it has NO effect when NODE_ENV=production, so it can never leak to prod.
# Leave blank everywhere except local development.
DEV_AUTH_BYPASS=""
DEV_USER_EMAIL="dev@hearst.local"

# =============================================================================
# PAYMENT (Privy) — https://dashboard.privy.io
# Privy is NOT used for authentication. It powers the USDC subscription/payment
# flow only (wallet connect at deposit time). Optional everywhere — the app
# boots and authenticates without it. Fill to enable the wallet payment flow.
# =============================================================================
NEXT_PUBLIC_PRIVY_APP_ID=""
PRIVY_APP_SECRET=""

# =============================================================================
# BLOCKCHAIN (Base Sepolia) — Phase 2+ smart contracts
# =============================================================================
NEXT_PUBLIC_CHAIN_RPC_URL=https://sepolia.base.org

# Phase 2 contracts — fill after `forge script` deploy.
NEXT_PUBLIC_EVENT_LOGGER_ADDRESS=""
NEXT_PUBLIC_POR_REGISTRY_ADDRESS=""

# =============================================================================
# ADMIN / OPS — comma-separated Ethereum addresses
# =============================================================================
ADMIN_ADDRESSES=""

# DEPLOYER_PRIVATE_KEY — DO NOT put here. Use .env.deploy (Foundry scripts only, never the app server).
HEARST_PUBLISHER=""

# =============================================================================
# RATE LIMITING (Upstash Redis) — required for multi-instance deployments
# =============================================================================
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""

# =============================================================================
# OBSERVABILITY (Sentry) — https://sentry.io
# All optional — project boots without them (no-op fallback).
# =============================================================================
SENTRY_DSN=""
NEXT_PUBLIC_SENTRY_DSN=""
SENTRY_AUTH_TOKEN=""
SENTRY_ORG=""
SENTRY_PROJECT=""

# =============================================================================
# ANALYTICS (PostHog) — https://posthog.com
# =============================================================================
NEXT_PUBLIC_POSTHOG_KEY=""
NEXT_PUBLIC_POSTHOG_HOST="https://us.i.posthog.com"

# =============================================================================
# BACKGROUND JOBS (Inngest) — https://www.inngest.com
# Required in production to authenticate job requests to /api/inngest.
# =============================================================================
INNGEST_SIGNING_KEY=""
INNGEST_EVENT_KEY=""

# =============================================================================
# COCKPIT CHAT (Hypercli / Kimi K2.6) — required for ChatKimi rail droit
# Get your key at https://hypercli.com — server-side only, never expose client-side.
# =============================================================================
HYPERCLI_API_KEY=""
HYPERCLI_BASE_URL="https://api.hypercli.com/v1"
HYPERCLI_DEFAULT_MODEL="kimi-k2.6"

# =============================================================================
# DEMO MODE — set to "1" to force deterministic fixtures on every request
# (no DB, no upstream APIs). Leave "0" in production; flip per-browser via the
# in-app toggle (cookie hearst-demo-mode=1, 24h TTL).
# =============================================================================
DEMO_MODE_DEFAULT=0

# =============================================================================
# OPTIONAL / FUTURE
# =============================================================================
