# =============================================================================
# REQUIRED
# =============================================================================

# Local dev: SQLite. Production: Postgres connection string.
DATABASE_URL="file:./prisma/dev.db"

# =============================================================================
# LLM (Anthropic) — required for agents (Investor Memo, Scenario Narrative,
# Mining Health, Risk Explanation). Leave blank to disable LLM features.
# =============================================================================
ANTHROPIC_API_KEY=""

# =============================================================================
# AUTH (Privy) — https://dashboard.privy.io
# Create an app, copy the App ID and Secret.
# Leave both blank in local dev to disable the gate (routes remain open).
# =============================================================================
NEXT_PUBLIC_PRIVY_APP_ID=""
PRIVY_APP_SECRET=""

# =============================================================================
# BLOCKCHAIN (Base Sepolia) — Phase 2+ smart contracts
# =============================================================================
NEXT_PUBLIC_CHAIN_RPC_URL=https://sepolia.base.org

# Phase 2 contracts — fill after `forge script` deploy.
NEXT_PUBLIC_EVENT_LOGGER_ADDRESS=""
NEXT_PUBLIC_POR_REGISTRY_ADDRESS=""

# =============================================================================
# ADMIN / OPS — comma-separated Ethereum addresses
# =============================================================================
ADMIN_ADDRESSES=""

# DEPLOYER_PRIVATE_KEY — DO NOT put here. Use .env.deploy (Foundry scripts only, never the app server).
HEARST_PUBLISHER=""

# =============================================================================
# RATE LIMITING (Upstash Redis) — required for multi-instance deployments
# =============================================================================
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""

# =============================================================================
# OBSERVABILITY (Sentry) — https://sentry.io
# All optional — project boots without them (no-op fallback).
# =============================================================================
SENTRY_DSN=""
NEXT_PUBLIC_SENTRY_DSN=""
SENTRY_AUTH_TOKEN=""
SENTRY_ORG=""
SENTRY_PROJECT=""

# =============================================================================
# ANALYTICS (PostHog) — https://posthog.com
# =============================================================================
NEXT_PUBLIC_POSTHOG_KEY=""
NEXT_PUBLIC_POSTHOG_HOST="https://us.i.posthog.com"

# =============================================================================
# BACKGROUND JOBS (Inngest) — https://www.inngest.com
# Required in production to authenticate job requests to /api/inngest.
# =============================================================================
INNGEST_SIGNING_KEY=""
INNGEST_EVENT_KEY=""

# =============================================================================
# COCKPIT CHAT (Hypercli / Kimi K2.6) — required for ChatKimi rail droit
# Get your key at https://hypercli.com — server-side only, never expose client-side.
# =============================================================================
HYPERCLI_API_KEY=""
HYPERCLI_BASE_URL="https://api.hypercli.com/v1"
HYPERCLI_DEFAULT_MODEL="kimi-k2.6"

# =============================================================================
# OPTIONAL / FUTURE
# =============================================================================
