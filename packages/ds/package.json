{
  "name": "@ds/core",
  "version": "0.1.0",
  "private": true,
  "description": "Token-first, multi-theme, multi-brand, multi-tenant enterprise design system. Zero hardcoded values. WCAG AAA. Stripe + Linear + Apple + Vercel quality.",
  "type": "module",
  "scripts": {
    "typecheck": "tsc --noEmit"
  },
  "sideEffects": [
    "./src/tokens/**/*.css",
    "./src/themes/**/*.css",
    "./src/motion/**/*.css"
  ],
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./tokens": "./src/tokens/index.css",
    "./themes/*": "./src/themes/*.css",
    "./tailwind": "./src/tailwind/preset.ts",
    "./primitives/*": "./src/primitives/*/index.ts",
    "./motion": "./src/motion/index.ts",
    "./utils": "./src/utils/index.ts",
    "./figma": "./tokens.figma.json"
  },
  "dependencies": {
    "@radix-ui/react-accordion": "^1.2.1",
    "@radix-ui/react-avatar": "^1.1.1",
    "@radix-ui/react-checkbox": "^1.1.2",
    "@radix-ui/react-dialog": "^1.1.2",
    "@radix-ui/react-dropdown-menu": "^2.1.2",
    "@radix-ui/react-popover": "^1.1.2",
    "@radix-ui/react-radio-group": "^1.2.1",
    "@radix-ui/react-select": "^2.1.2",
    "@radix-ui/react-slider": "^1.2.1",
    "@radix-ui/react-slot": "^1.1.0",
    "@radix-ui/react-switch": "^1.1.1",
    "@radix-ui/react-tabs": "^1.1.1",
    "@radix-ui/react-toast": "^1.2.2",
    "@radix-ui/react-tooltip": "^1.1.4",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "framer-motion": "^11.11.17",
    "lucide-react": "^0.469.0",
    "tailwind-merge": "^2.5.5",
    "tailwind-variants": "^0.3.0"
  },
  "peerDependencies": {
    "react": ">=18",
    "react-dom": ">=18",
    "tailwindcss": ">=4"
  },
  "devDependencies": {
    "@types/react": ">=18"
  }
}
